{
  "name": "code-dual-root",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "prepare": "husky || echo 'Husky skipped'",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "dev": "npm run dev --workspaces --if-present",
    "db:push": "npm run db:push -w server",
    "db:seed": "npm run db:seed -w server",
    "setup": "npm install && npm --prefix server run build || echo 'Build skip' && cd server && npx prisma generate && npx prisma db push && npx prisma db seed"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
